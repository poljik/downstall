# ==========================================
# Downstall Environment Configuration
# ==========================================

# Network & Anti-Bot settings
DOWNSTALL_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
DOWNSTALL_CHECK_DOMAIN="google.com"

# API Endpoints & Base URLs
DOWNSTALL_GITHUB_API_BASE="https://api.github.com"
DOWNSTALL_YANDEX_API_URL="https://cloud-api.yandex.net/v1/disk/public/resources"
DOWNSTALL_YANDEX_API_DL="https://cloud-api.yandex.net:443/v1/disk/public/resources/download"
DOWNSTALL_GOOGLE_DRIVE_API="https://drive.google.com/uc?export=download&id="

# Specific Software URLs (Scraping Fallbacks)
DOWNSTALL_IRFANVIEW_URL="https://www.irfanview.com/"
DOWNSTALL_OPERA_URL="https://get.geo.opera.com/pub/opera/desktop/"
DOWNSTALL_SOFTETHER_URL="http://www.softether-download.com/files/softether/"

# Special Installations
DOWNSTALL_OFFICE_ODT_URL="https://www.microsoft.com/en-us/download/details.aspx?id=49117"
DOWNSTALL_MAS_URL="https://get.activated.win"

# Authentication (Optional, leave empty if not used)
# Use your personal access token to prevent GitHub API rate limits (60 req/hour for unauthenticated)
GITHUB_TOKEN=""
